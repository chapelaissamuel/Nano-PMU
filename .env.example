# ============================================================
# nano-pmu — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ============================================================

# Token du bot Telegram (obtenu depuis @BotFather)
TELEGRAM_BOT_TOKEN=

# ID du chat/canal Telegram (@userinfobot pour le trouver)
TELEGRAM_CHAT_ID=

# Token GitHub (scope: repo) — github.com/settings/tokens
GITHUB_TOKEN=

# Nom du repo GitHub au format: utilisateur/nom-du-repo
GITHUB_REPO=chapelaissamuel/Nano-PMU
